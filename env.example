# ============================================================
# FinTrack Environment Variables — Template
# Copy this file as .env and fill in your values.
# Never commit the actual .env file to version control.
# ============================================================

# PostgreSQL
POSTGRES_DB=fintrack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sa123

# Spring Boot
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/fintrack
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=sa123

# JWT — must be at least 32 characters
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRATION=86400000
